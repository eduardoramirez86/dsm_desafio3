<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <domain-config>
        <domain includeSubdomains="true">mockapi.io</domain>

        <domain includeSubdomains="true">m.media-amazon.com</domain>
        <domain includeSubdomains="true">upload.wikimedia.org</domain>
        <domain includeSubdomains="true">cdn.icon-icons.com</domain>
        <domain includeSubdomains="true">git-scm.com</domain>
        <domain includeSubdomains="true">martinfowler.com</domain>
        <domain includeSubdomains="true">avatars.githubusercontent.com</domain>
    </domain-config>

    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

</network-security-config>